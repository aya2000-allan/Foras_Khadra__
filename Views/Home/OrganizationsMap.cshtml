@model List<Foras_Khadra.Models.Organization>
@using Microsoft.AspNetCore.Mvc.Localization
@using System.Text.Json
@inject IViewLocalizer Localizer

@using System.Globalization

@{
    string GetCountryName(string code)
    {
        var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

        return code switch
        {
            // Jordan
            "JO" => lang == "ar" ? "الأردن" : lang == "fr" ? "Jordanie" : "Jordan",

            // Palestine
            "PS" => lang == "ar" ? "فلسطين" : lang == "fr" ? "Palestine" : "Palestine",

            // Egypt
            "EG" => lang == "ar" ? "مصر" : lang == "fr" ? "Égypte" : "Egypt",

            // Yemen
            "YE" => lang == "ar" ? "اليمن" : lang == "fr" ? "Yémen" : "Yemen",

            // India
            "IN" => lang == "ar" ? "الهند" : lang == "fr" ? "Inde" : "India",

            // Algeria
            "DZ" => lang == "ar" ? "الجزائر" : lang == "fr" ? "Algérie" : "Algeria",

            // Lebanon
            "LB" => lang == "ar" ? "لبنان" : lang == "fr" ? "Liban" : "Lebanon",

            // Tunisia
            "TN" => lang == "ar" ? "تونس" : lang == "fr" ? "Tunisie" : "Tunisia",

            // Oman
            "OM" => lang == "ar" ? "عُمان" : lang == "fr" ? "Oman" : "Oman",

            // Iraq
            "IQ" => lang == "ar" ? "العراق" : lang == "fr" ? "Irak" : "Iraq",

            // Morocco
            "MA" => lang == "ar" ? "المغرب" : lang == "fr" ? "Maroc" : "Morocco",

            // Syria
            "SY" => lang == "ar" ? "سوريا" : lang == "fr" ? "Syrie" : "Syria",

            _ => code
        };
    }
}
@{
    ViewData["Title"] = Localizer["PageTitle"];
    var loginTitle = JsonSerializer.Serialize(Localizer["LoginRequiredTitle"].Value);
    var loginText = JsonSerializer.Serialize(Localizer["LoginRequiredText"].Value);
    var loginBtn = JsonSerializer.Serialize(Localizer["LoginButton"].Value);
    var noResultsTitle = JsonSerializer.Serialize(Localizer["NoResults"].Value);
    var noResultsHint = JsonSerializer.Serialize(Localizer["NoResultsHint"].Value);
    var closeLbl = JsonSerializer.Serialize(Localizer["close"].Value);
    var resetLbl = JsonSerializer.Serialize(Localizer["reset"].Value);
    var resetMapUrl = JsonSerializer.Serialize(Url.Action("OrganizationsMap", "Home"));
    var showNoResultsPopup = Model == null || !Model.Any();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
<link rel="stylesheet" href="~/css/OrgMap.css" />

<div class="page-wrapper container org-map-page">

    <header class="org-map-header custom-header">
        <div class="header-right">
            <div class="header-logo">
                <img src="/images/about_us_leaf.svg" alt="" />
            </div>
            <h1 class="header-title">@Localizer["PageTitle"]</h1>
        </div>
        <div class="header-left">
            <div class="filter-btn" id="orgMapFilterBtn" role="button" tabindex="0" aria-haspopup="true" aria-expanded="false" title="@Localizer["filter_heading"]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="4" y1="21" x2="4" y2="14" />
                    <line x1="4" y1="10" x2="4" y2="3" />
                    <line x1="12" y1="21" x2="12" y2="12" />
                    <line x1="12" y1="8" x2="12" y2="3" />
                    <line x1="20" y1="21" x2="20" y2="16" />
                    <line x1="20" y1="12" x2="20" y2="3" />
                    <line x1="1" y1="14" x2="7" y2="14" />
                    <line x1="9" y1="8" x2="15" y2="8" />
                    <line x1="17" y1="16" x2="23" y2="16" />
                </svg>
            </div>
        </div>

        <div class="org-map-filter-window filter-window shadow" id="orgMapFilterWindow" role="dialog" aria-label="@Localizer["filter_heading"]">
            <div class="filter-window-header">
                <span class="sort-by-label">
                    @Localizer["filter_heading"]
                    <i class="bi bi-caret-up-fill filter-heading-caret" aria-hidden="true"></i>
                </span>
                <a href="@Url.Action("OrganizationsMap", "Home")" class="reset-link">@Localizer["reset"]</a>
            </div>
            <form method="get" class="org-map-filter-form">
                <div class="mb-3">
                    <label class="org-map-label d-block" for="mapCountry">@Localizer["country"]</label>
                    <select name="country" id="mapCountry" class="form-control org-map-select">
                        <option value="">@Localizer["AllCountries"]</option>
                        @foreach (var country in ViewBag.Countries)
                        {
                            <option value="@country" selected="@(ViewBag.SelectedCountry == country ? "selected" : null)">
                                @GetCountryName(country)
                            </option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="org-map-label d-block" for="mapSector">@Localizer["sector_label"]</label>
                    <select name="sector" id="mapSector" class="form-control org-map-select">
                        <option value="">@Localizer["AllSectors"]</option>
                        @foreach (var s in ViewBag.Sectors)
                        {
                            <option value="@s" selected="@(ViewBag.SelectedSector == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="org-map-filter-actions">
                    <button type="button" class="btn-cancel-sub" id="orgMapFilterClose">@Localizer["cancel"]</button>
                    <button type="submit" class="btn-search-sub">@Localizer["apply"]</button>
                </div>
            </form>
        </div>
    </header>

    <div class="network-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var org in Model)
            {
                <div class="org-wrapper">
                    <div class="org-card"
                         data-org-id="@org.Id"
                         tabindex="0"
                         role="button"
                         aria-label="@Localizer["LabelOrganizationName"] @org.Name">
                        <div class="org-card-body">
                            <img src="@org.LogoPath" class="org-logo" alt="logo" />

                            <div class="org-card-hover" aria-hidden="true">
                                <div class="org-card-text">
                                    <div class="org-name">@org.Name</div>
                                    <div class="org-meta org-disc-sector">@org.Sector</div>
                                    <div class="org-meta org-disc-country">
                                        @GetCountryName(org.Country)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="org-map-empty-grid" id="orgMapEmptyGrid" role="status" aria-live="polite"></div>
        }
    </div>
</div>

<div class="pagination-container org-map-pagination">
    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a class="page-number org-map-page-link @(ViewBag.CurrentPage == i ? "active" : "")"
           href="@Url.Action("OrganizationsMap", "Home", new { page = i, country = ViewBag.SelectedCountry, sector = ViewBag.SelectedSector })">
            @i
        </a>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
        (function () {
            const filterBtn = document.getElementById('orgMapFilterBtn');
            const filterWindow = document.getElementById('orgMapFilterWindow');
            const closeBtn = document.getElementById('orgMapFilterClose');

            function setOpen(open) {
                if (!filterWindow || !filterBtn) return;
                filterWindow.classList.toggle('is-open', open);
                filterBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
            }

            if (filterBtn && filterWindow) {
                filterBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    setOpen(!filterWindow.classList.contains('is-open'));
                });
                filterBtn.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        setOpen(!filterWindow.classList.contains('is-open'));
                    }
                });
            }
            if (closeBtn) {
                closeBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    setOpen(false);
                });
            }
            document.addEventListener('click', function (e) {
                if (filterWindow && filterBtn && filterWindow.classList.contains('is-open') &&
                    !filterWindow.contains(e.target) && !filterBtn.contains(e.target)) {
                    setOpen(false);
                }
            });
        })();

        const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();
        const L = { loginTitle: @Html.Raw(loginTitle), loginText: @Html.Raw(loginText), loginBtn: @Html.Raw(loginBtn) };

        document.querySelectorAll(".org-card").forEach(function (card) {
        card.addEventListener("click", function () {
            const orgId = this.dataset.orgId;

            if (!isAuthenticated) {
                Swal.fire({
                    icon: "warning",
                    title: L.loginTitle,
                    text: L.loginText,
                    confirmButtonText: L.loginBtn,
                    confirmButtonColor: "#F99D27"
                }).then(function (result) {
                    if (result.isConfirmed) {
                        window.location.href = "/Account/Login";
                    }
                });
            } else {
                window.location.href = "/Home/DetailsOrganization/" + orgId;
            }
        });
    });

        (function showNoResultsModal() {
            if (!@showNoResultsPopup.ToString().ToLower()) return;
            var empty = {
                title: @Html.Raw(noResultsTitle),
                hint: @Html.Raw(noResultsHint),
                close: @Html.Raw(closeLbl),
                reset: @Html.Raw(resetLbl),
                resetUrl: @Html.Raw(resetMapUrl)
            };
            var isRtl = (document.documentElement.getAttribute("dir") || "ltr") === "rtl";
            Swal.fire({
                customClass: {
                    popup: "org-map-no-results-swal",
                    title: "org-map-no-results-title",
                    confirmButton: "btn-search-sub",
                    cancelButton: "btn-cancel-sub"
                },
                buttonsStyling: false,
                icon: false,
                title: empty.title,
                html:
                    '<div class="org-map-no-results-visual">' +
                    '<span class="org-map-no-results-icon-ring">' +
                    '<svg class="org-map-no-results-svg" viewBox="0 0 24 24" width="42" height="42" aria-hidden="true" focusable="false">' +
                    '<circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2"/>' +
                    '<path d="M16 16l4.5 4.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' +
                    '<path d="M6 6l9 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>' +
                    '</svg></span></div>' +
                    '<p class="org-map-no-results-hint">' + empty.hint + '</p>',
                showCancelButton: true,
                focusConfirm: false,
                confirmButtonText: empty.reset,
                cancelButtonText: empty.close,
                reverseButtons: isRtl,
                didOpen: function () {
                    var p = Swal.getPopup();
                    if (p) p.setAttribute("dir", isRtl ? "rtl" : "ltr");
                }
            }).then(function (result) {
                if (result.isConfirmed) {
                    window.location.href = empty.resetUrl;
                }
            });
        })();
</script>