@model List<Foras_Khadra.Models.ManualOrganization>
@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
    ViewData["HideNavAndFooter"] = true;
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var dir = culture == "ar" ? "rtl" : "ltr";
    var titleAlignClass = culture == "ar" ? "text-end" : "text-start";
}

@section Styles {
    <link rel="stylesheet" asp-append-version="true" href="~/css/manual-organizations-list.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}

<div class="container py-5 manual-org-page" dir="@dir">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-6 @titleAlignClass">
            <h2 class="main-title mb-0">@Localizer["PageTitle"]</h2>
        </div>

        <div class="col-md-6 d-flex justify-content-md-end align-items-center gap-3 d-flex-mobile">
            <a class="btn btn-add" asp-controller="Admin" asp-action="AddManualOrganization">
                <i class="fa-solid fa-plus ms-1"></i> @Localizer["AddOrganization"]
            </a>

            <a asp-controller="Admin" asp-action="Dashboard" class="btn-back-dashboard">
                <i class="fa-solid fa-gauge"></i>
                @Localizer["BackToDashboard"]
            </a>
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table manual-org-table">
                <thead>
                    <tr>
                        <th style="width:80px;"></th>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Contact"]</th>
                        <th>@Localizer["Phone"]</th>
                        <th>@Localizer["Email"]</th>
                        <th>@Localizer["Country"]</th>
                        <th>@Localizer["Status"]</th>
                        <th class="text-center">@Localizer["Actions"]</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.LogoPath) ? Url.Content("~/images/about_us_leaf.svg") : item.LogoPath)"
                                     class="rounded"
                                     style="width:50px;height:50px;object-fit:cover;"
                                     alt="@Localizer["OrganizationLogoAlt"]" />
                            </td>
                            <td class="fw-bold text-dark">@item.OrganizationName</td>
                            <td class="text-muted">@item.ContactPersonName</td>
                            <td class="text-muted">@item.PhoneNumber</td>
                            <td class="text-muted">@item.Email</td>
                            <td class="text-muted">@item.Country</td>
                            <td>
                                <span class="status-badge @(item.IsActive == true ? "status-active" : "status-inactive")">
                                    @(item.IsActive == true ? Localizer["Active"] : Localizer["Inactive"])
                                </span>
                            </td>
                            <td>
                                <div class="d-flex justify-content-center">
                                    <a class="action-icon icon-edit"
                                       href="/Admin/EditManualOrganization/@item.Id"
                                       title="@Localizer["Edit"]">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    <a class="action-icon icon-view"
                                       href="/Admin/ManualOrganizationDetails/@item.Id"
                                       title="@Localizer["Details"]">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    <form method="post"
                                          action="/Admin/DeleteManualOrganization"
                                          class="d-inline"
                                          id="deleteForm-@item.Id">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="button"
                                                class="action-icon icon-delete"
                                                title="@Localizer["Delete"]"
                                                data-id="@item.Id"
                                                data-name="@item.OrganizationName"
                                                onclick="confirmDelete(this)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(button) {
            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name') || '';
            Swal.fire({
                html: `
                    <div style="text-align:center;">
                        <img src="/images/delete.svg" style="margin-bottom:14px;" />
                        <h5 style="margin:0 0 10px 0;font-weight:700;color:#000;">
                            @Localizer["DeletePopupTitle"]
                        </h5>
                    </div>
                `,
                input: 'text',
                inputValue: name,
                inputAttributes: { readonly: true },
                showCancelButton: true,
                confirmButtonText: '@Localizer["DeleteButton"]',
                cancelButtonText: '@Localizer["CancelButton"]',
                reverseButtons: true,
                buttonsStyling: false,
                customClass: {
                    popup: 'swal-rtl-popup',
                    input: 'swal-rtl-input',
                    confirmButton: 'swal-btn swal-btn-danger',
                    cancelButton: 'swal-btn swal-btn-cancel'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.getElementById('deleteForm-' + id);
                    if (form) form.submit();
                }
            });
        }
    </script>
    <style>
        .swal-rtl-popup {
            direction: rtl;
            border-radius: 20px;
            padding: 24px 28px;
            width: 420px;
            max-width: 90vw;
            font-family: 'Cairo', sans-serif;
            text-align: center;
            background: #F6FBF7;
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }

        .swal-rtl-input {
            text-align: center !important;
            border: none !important;
            box-shadow: none !important;
            background: transparent !important;
            font-weight: 600;
            color: #25652C;
            font-size: 16px;
            margin-top: 8px;
            pointer-events: none;
        }

        .swal2-actions {
            display: flex !important;
            justify-content: center;
            gap: 12px;
        }

        .swal-btn {
            min-width: 130px;
            padding: 12px 20px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
        }

        .swal-btn-danger {
            background: #ff383c;
            color: #fff;
        }

        .swal-btn-danger:hover {
            background: #e02f31;
        }

        .swal-btn-cancel {
            background: #fff;
            color: #f99d27;
            border: 2px solid #f99d27;
        }

        .swal-btn-cancel:hover {
            background: #f99d27;
            color: #fff;
        }
    </style>
}