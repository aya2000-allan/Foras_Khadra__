@model List<Foras_Khadra.Models.ManualOrganization>

@{
    ViewData["Title"] = "Manual Organizations";
}

<h2>Manual Organizations</h2>

<a class="btn btn-primary mb-3" href="/Admin/AddManualOrganization">
    + Add Organization
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Logo</th>

            
            <th>Name</th>
            <th>Contact</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Country</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.LogoPath))
                    {
                        <img src="@item.LogoPath" width="50" height="50" />
                    }
                </td>
                <td>@item.OrganizationName</td>
                <td>@item.ContactPersonName</td>
                <td>@item.PhoneNumber</td>
                <td>@item.Email</td>
                <td>@item.Country</td>
                <td>
                    @(item.IsActive == true ? "Active" : "Inactive")
                </td>
                <td>
                    <a class="btn btn-sm btn-warning"
                       href="/Admin/EditManualOrganization/@item.Id">
                        Edit
                    </a>

                    <a class="btn btn-sm btn-info"
                       href="/Admin/ManualOrganizationDetails/@item.Id">
                        Details
                    </a>

                    <form method="post"
                          action="/Admin/DeleteManualOrganization"
                          style="display:inline;">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-danger"
                                onclick="return confirm('Delete this organization?')">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>