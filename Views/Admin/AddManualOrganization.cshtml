@model Foras_Khadra.Models.ManualOrganization

@{
    ViewData["Title"] = "Add Organization";
}

<h2>Add Manual Organization</h2>

<form method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label>Logo</label>
        <input type="file" name="logoFile" class="form-control" />
    </div>

    <div class="form-group">
        <label>Name</label>
        <input asp-for="OrganizationName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Sector</label>
        <input asp-for="Sector" class="form-control" />
    </div>

    <div class="form-group">
        <label>Contact Person</label>
        <input asp-for="ContactPersonName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Details</label>
        <textarea asp-for="Details" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Phone</label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Website</label>
        <input asp-for="Website" class="form-control" />
    </div>

    <div class="form-group">
        <label>Location</label>
        <input asp-for="Location" class="form-control" />
    </div>

    <div class="form-group">
        <label>Country</label>
        <input asp-for="Country" class="form-control" />
    </div>

    <div class="form-group form-check">
        <input type="hidden" asp-for="IsActive" value="false" />

    </div>

    <button type="submit" class="btn btn-success mt-3">
        Save
    </button>

</form>