@model Foras_Khadra.Models.Organization

@{
    ViewData["Title"] = "تفاصيل المنظمة";
}

<h2>تفاصيل المنظمة: @Model.Name</h2>

@if (User.IsInRole("Admin") && !string.IsNullOrEmpty(Model.LogoPath))
{
    <div class="mb-3">
        <img src="@Model.LogoPath" style="width:150px; height:150px; object-fit:cover; border-radius:50%;" />

        <form asp-action="DeleteLogo" method="post" class="mt-2">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger btn-sm">حذف اللوجو</button>
        </form>
    </div>
}

<table class="table table-bordered mt-3">
    <tr>
        <th>اسم المنظمة</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>القطاع</th>
        <td>@Model.Sector</td>
    </tr>
    <tr>
        <th>الدولة</th>
        <td>@Model.Country</td>
    </tr>
    <tr>
        <th>جهة الاتصال</th>
        <td>@Model.ContactName</td>
    </tr>
    <tr>
        <th>البريد الإلكتروني</th>
        <td>@Model.ContactEmail</td>
    </tr>
    <tr>
        <th>رقم الهاتف</th>
        <td>@Model.PhoneNumber</td>
    </tr>
    <tr>
        <th>الموقع الإلكتروني</th>
        <td>
            @if (!string.IsNullOrEmpty(Model.Website))
            {
                <a href="@Model.Website" target="_blank">@Model.Website</a>
            }
        </td>
    </tr>
    <tr>
        <th>تاريخ التسجيل</th>
        <td>@Model.CreatedAt.ToString("yyyy-MM-dd")</td>
    </tr>
</table>
@if (User.IsInRole("Admin"))
{
    <form asp-action="UploadLogo" method="post" enctype="multipart/form-data" class="mt-3">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-2">
            <input type="file" name="logoFile" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">رفع اللوجو</button>
    </form>
}
<a asp-controller="Admin" asp-action="OrganizationsList" class="btn btn-secondary mt-3">
    العودة للقائمة
</a>
