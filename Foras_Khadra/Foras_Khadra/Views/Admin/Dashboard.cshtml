@model Foras_Khadra.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;

    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = lang == "ar";
    var dir = isArabic ? "rtl" : "ltr";
}

<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        :root {
            --bg: #f5f7f4;
            --panel: #ffffff;
            --sidebar: #f3f5f2;
            --sidebar-border: #d8ddd6;
            --text: #213126;
            --muted: #8a928d;
            --accent-green: #2f6b3c;
            --accent-green-soft: #dfe7df;
            --accent-orange: #f99d27;
            --accent-orange-soft: #eee6d9;
            --danger: #d9534f;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
            --radius-xl: 24px;
            --radius-lg: 18px;
            --radius-md: 14px;
            --radius-sm: 10px;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100%;
            background: #fff;
            color: var(--text);
            font-family: "Segoe UI", Tahoma, Arial, sans-serif;
        }

        body {
            min-height: 100vh;
        }

        .dashboard-shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: #F6F6F6;
            border-inline-end: 1px solid var(--sidebar-border);
            box-shadow: 0 0 24px rgba(0, 0, 0, 0.03);
            padding: 18px 16px 24px;
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            z-index: 10;
        }

        .full-width {
            grid-column: 1 / -1;
        }

        .bottom-cards {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }
        .brand-box {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 8px 8px 18px;
            margin-bottom: 8px;
        }

        .brand-logo {
            width: 58px;
            height: 58px;
            object-fit: contain;
            flex-shrink: 0;
        }

        .custom-dropdown {
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
        }

        .logout-item {
            color: #7a1f2b; /* خمري */
            font-weight: 600;
            border-radius: 8px;
        }

            .logout-item:hover {
                background: #f8e4e7;
                color: #5a1620;
            }

        .brand-title {
            font-size: 16px;
            font-weight: 500;
            margin: 0;
            color: var(--text);
        }

        .sidebar-section {
            margin-top: 10px;
        }

        .sidebar-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: .08em;
            text-transform: uppercase;
            margin: 16px 10px 10px;
        }

        .nav-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: var(--text);
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 15px;
            font-weight: 600;
            transition: .2s ease;
        }

        .nav-link-item i {
            font-size: 18px;
            color: #6f7b73;
            width: 20px;
            text-align: center;
        }

        .nav-link-item:hover {
            background: #e8ede7;
            color: var(--text);
        }

        .nav-link-item.active {
            background: #dbe5da;
            color: var(--text);
        }

        .nav-link-item.active i {
            color: var(--accent-green);
        }

        .sidebar-spacer {
            flex: 1;
        }

        .logout-form {
            margin-top: 16px;
        }

        .logout-btn {
            width: 100%;
            border: none;
            background: transparent;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 12px;
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 15px;
            font-weight: 600;
            transition: .2s ease;
        }

        .logout-btn i {
            font-size: 18px;
            color: #6f7b73;
        }

        .logout-btn:hover {
            background: #fbe8e8;
            color: #8f2f2f;
        }

        .main-content {
            flex: 1;
            padding: 24px 28px 40px;
        }

        .topbar {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 24px;
        }

        .breadcrumb-box {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .mini-breadcrumb {
            font-size: 13px;
            color: var(--muted);
        }

        .mini-breadcrumb span {
            color: var(--text);
            font-weight: 600;
        }

        .page-name {
            font-size: 18px;
            font-weight: 800;
            margin: 0;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #7b8792;
            font-weight: 700;
            font-size: 14px;
            white-space: nowrap;
        }

        .user-chip i {
            font-size: 22px;
        }

        .hero-card {
            background: transparent;
            border-radius: 20px;
            margin-bottom: 18px;
        }

        .hero-title {
            font-size: 34px;
            font-weight: 800;
            margin: 0 0 6px;
            color: var(--text);
        }

        .hero-subtitle {
            font-size: 15px;
            color: var(--muted);
            margin: 0;
        }

        .stats-wrapper {
            background: var(--panel);
            border-radius: 24px;
            padding: 20px;
            box-shadow: var(--shadow);
        }

        .stats-header {
            margin-bottom: 18px;
        }

        .stats-title {
            font-size: 28px;
            font-weight: 800;
            margin: 0 0 4px;
        }

        .stats-subtitle {
            margin: 0;
            color: var(--muted);
            font-size: 14px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 16px;
        }

        .stats-card {
            border: none;
            border-radius: 18px;
            min-height: 140px;
            padding: 18px 16px;
            cursor: pointer;
            transition: transform .22s ease, box-shadow .22s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .stats-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
        }

        .stats-card.green-soft {
            background: var(--accent-green-soft);
        }

        .stats-card.orange-soft {
            background: var(--accent-orange-soft);
        }

        .stats-card.red-soft {
            background: #f4dede;
        }

        .stats-card .icon-wrap {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-inline-start: auto;
            margin-bottom: 18px;
            color: #fff;
            font-size: 22px;
        }

        .stats-card .icon-wrap.green {
            background: var(--accent-green);
        }

        .stats-card .icon-wrap.orange {
            background: var(--accent-orange);
        }

        .stats-card .icon-wrap.red {
            background: var(--danger);
        }

        .stats-number {
            font-size: 34px;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 8px;
            color: #16261a;
        }

        .stats-label {
            font-size: 16px;
            font-weight: 700;
            color: #445347;
        }

        .stats-hint {
            font-size: 12px;
            color: #7d877f;
            margin-top: 6px;
        }

        .section-gap {
            height: 18px;
        }

        @@media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        @@media (max-width: 991px) {
            .dashboard-shell {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-inline-end: none;
                border-bottom: 1px solid var(--sidebar-border);
            }

            .main-content {
                padding: 20px 16px 32px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .hero-title {
                font-size: 28px;
            }
        }

        @@media (max-width: 576px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stats-title {
                font-size: 22px;
            }

            .hero-title {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-shell">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand-box">
                <img src="~/images/logodash.png" alt="Foras Khadra" class="brand-logo" />
                <h1 class="brand-title">Foras Khadra</h1>
            </div>

            <div class="sidebar-section">
                <span class="sidebar-label">Dashboard</span>
                <div class="nav-list">
                    <a asp-controller="Admin" asp-action="Dashboard" class="nav-link-item active">
                        <i class="bi bi-grid"></i>
                        <span>@(isArabic ? "الرئيسية" : "Home")</span>
                    </a>
                </div>
            </div>

            <div class="sidebar-section">
                <span class="sidebar-label">Articles</span>
                <div class="nav-list">
                    <a asp-controller="Articles" asp-action="Index" class="nav-link-item">
                        <i class="bi bi-file-text"></i>
                        <span>@(isArabic ? "عرض المقالات" : "All articles")</span>
                    </a>
                    <a asp-controller="Articles" asp-action="Create" class="nav-link-item">
                        <i class="bi bi-plus-circle"></i>
                        <span>@(isArabic ? "إضافة مقال" : "Add article")</span>
                    </a>
                    
                </div>
            </div>

            <div class="sidebar-section">
                <span class="sidebar-label">Member</span>
                <div class="nav-list">
                    <a asp-controller="Team" asp-action="Index" class="nav-link-item">
                        <i class="bi bi-people"></i>
                        <span>@(isArabic ? "عرض الأعضاء" : "All members")</span>
                    </a>
                    <a asp-controller="Team" asp-action="Create" class="nav-link-item">
                        <i class="bi bi-plus-circle"></i>
                        <span>@(isArabic ? "إضافة عضو" : "Add member")</span>
                    </a>
                </div>
            </div>

            <div class="sidebar-section">
                <span class="sidebar-label">Opportunities</span>
                <div class="nav-list">
                    <a asp-controller="Opportunity" asp-action="Index" class="nav-link-item">
                        <i class="bi bi-briefcase"></i>
                        <span>@(isArabic ? "عرض الفرص" : "All opportunities")</span>
                    </a>
                    <a asp-controller="Opportunity" asp-action="Create" class="nav-link-item">
                        <i class="bi bi-plus-circle"></i>
                        <span>@(isArabic ? "إضافة فرصة" : "Add opportunity")</span>
                    </a>
                    
                </div>
            </div>

            <div class="sidebar-spacer"></div>

            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>@(isArabic ? "تسجيل الخروج" : "Log out")</span>
                </button>
            </form>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="topbar">
                <div class="breadcrumb-box">
                    <div class="mini-breadcrumb">
                        @(isArabic ? "الصفحات" : "Pages") / <span>@(isArabic ? "الرئيسية" : "Home")</span>
                    </div>
                    <h2 class="page-name">@(isArabic ? "الرئيسية" : "Home")</h2>
                </div>

                <div class="dropdown">
                    <div class="user-chip dropdown-toggle" data-bs-toggle="dropdown" style="cursor:pointer;">
                        <i class="bi bi-person-fill"></i>
                        <span>@(isArabic ? "اسم المستخدم" : "Username")</span>
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end custom-dropdown">
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item logout-item">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    @(isArabic ? "تسجيل الخروج" : "Log out")
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>

            <section class="hero-card">
                <h3 class="hero-title">
    @(isArabic ? "مرحبًا بك في لوحة تحكم الأدمن" : "Welcome to the Admin Dashboard")
    <span>👋</span>
</h3>
                <p class="hero-subtitle">
                    @(isArabic ? "إليك آخر الإحصائيات الخاصة بلوحة التحكم." : "Here is the latest dashboard summary.")
                </p>
            </section>

            <section class="stats-wrapper">
                <div class="stats-header">
                    <h3 class="stats-title">@(isArabic ? "آخر تحديث" : "Last Update")</h3>
                    <p class="stats-subtitle">@(isArabic ? "الإحصائيات" : "Statistics")</p>
                </div>

                <div class="stats-grid">
                    <div class="stats-card green-soft"
                         onclick="location.href='@Url.Action("OrganizationsList", "Admin")'">
                        <div class="icon-wrap green">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalOrganizations</div>
                            <div class="stats-label">@(isArabic ? "المنظمات" : "Organizations")</div>
                        </div>
                    </div>

                    <div class="stats-card orange-soft"
                         onclick="location.href='@Url.Action("Index", "Team")'">
                        <div class="icon-wrap orange">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalUsers</div>
                            <div class="stats-label">@(isArabic ? "الأعضاء" : "Members")</div>
                        </div>
                    </div>

                    <div class="stats-card orange-soft">
                        <div class="icon-wrap orange">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalRegisteredUsers </div>
                            <div class="stats-label">@(isArabic ? "المستخدمين المسجلين" : "Registered Users")</div>
                        </div>
                    </div>

                    

                    <div class="stats-card green-soft"
                         onclick="location.href='@Url.Action("Index", "Opportunity")'">
                        <div class="icon-wrap green">
                            <i class="bi bi-megaphone"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalOpportunities</div>
                            <div class="stats-label">@(isArabic ? "الفرص" : "Opportunities")</div>
                        </div>
                    </div>

                    <div class="stats-card orange-soft"
                         onclick="location.href='@Url.Action("Index", "Articles")'">
                        <div class="icon-wrap orange">
                            <i class="bi bi-chat-dots"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalArticles</div>
                            <div class="stats-label">@(isArabic ? "المقالات" : "Articles")</div>
                        </div>
                    </div>

                    <div class="stats-card green-soft full-width"
                         onclick="location.href='@Url.Action("ReelsRequestsDashboard", "Admin")'">
                        <div class="icon-wrap green">
                            <i class="bi bi-camera-reels"></i>
                        </div>
                        <div>
                            <div class="stats-number">@Model.TotalReelsRequests</div>
                            <div class="stats-label">@(isArabic ? "الطلبات المستلمة" : "Received Requests")</div>
                        </div>
                    </div>

                    <div class="bottom-cards">

                        <div class="stats-card orange-soft"
                             onclick="location.href='@Url.Action("ReelsRequestsDashboard", "Admin", new { status = "pending" })'">
                            <div class="icon-wrap orange">
                                <i class="bi bi-hourglass-split"></i>
                            </div>
                            <div>
                                <div class="stats-number">@Model.PendingReelsRequests</div>
                                <div class="stats-label">@(isArabic ? "جاري العمل عليها" : "In Progress")</div>
                            </div>
                        </div>

                        <div class="stats-card green-soft"
                             onclick="location.href='@Url.Action("ReelsRequestsDashboard", "Admin", new { status = "completed" })'">
                            <div class="icon-wrap green">
                                <i class="bi bi-check2-circle"></i>
                            </div>
                            <div>
                                <div class="stats-number">@Model.CompletedReelsRequests</div>
                                <div class="stats-label">@(isArabic ? "تم الانتهاء" : "Completed")</div>
                            </div>
                        </div>

                        <div class="stats-card red-soft"
                             onclick="location.href='@Url.Action("ReelsRequestsDashboard", "Admin", new { status = "rejected" })'">
                            <div class="icon-wrap red">
                                <i class="bi bi-x-circle"></i>
                            </div>
                            <div>
                                <div class="stats-number">@Model.RejectReelsRequests</div>
                                <div class="stats-label">@(isArabic ? "مرفوضة" : "Rejected")</div>
                            </div>
                        </div>

                    </div>
                </div>
            </section>
        </main>
    </div>
</body>
</html>