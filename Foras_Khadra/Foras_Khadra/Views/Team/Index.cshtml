@model IEnumerable<Foras_Khadra.Models.TeamMember>

@{
    ViewData["Title"] = "Team";
    Layout = "_Layout";

    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string search = ViewBag.Search as string;
    string selectedDepartment = ViewBag.SelectedDepartment as string;
}


@section Styles {
    <link rel="stylesheet" asp-append-version="true" href="~/css/articles-index.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
}

<div class="container py-5" dir="rtl">

    <!-- الرأس -->
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-6 text-center text-md-start">
            <h2 class="main-title mb-0">أعضاء الفريق</h2>
        </div>

        <div class="col-md-6 d-flex justify-content-md-end align-items-center gap-3 d-flex-mobile">
            <form method="get" class="d-flex align-items-center gap-2 flex-grow-1 flex-md-grow-0 w-100">
                <input type="hidden" name="department" id="departmentFilterInput" value="@selectedDepartment" />
                <div class="search-wrapper search-wrapper-team d-flex align-items-center flex-grow-1">
                    <i class="fa-solid fa-magnifying-glass text-muted ms-2"></i>
                    <input type="text"
                           name="search"
                           value="@search"
                           class="form-control border-0 shadow-none bg-transparent"
                           placeholder="البحث..." />
                    <div class="filter-dropdown">
                        <button type="button" class="filter-summary" id="teamFilterToggle" title="فلترة حسب القسم">
                            <i class="fa-solid fa-sliders text-muted cursor-pointer"></i>
                        </button>
                        <div class="filter-menu" id="teamFilterMenu">
                            <button type="button"
                                    data-filter-value=""
                                    class="filter-menu-item @(string.IsNullOrEmpty(selectedDepartment) ? "active" : "")">
                                كل الأقسام
                            </button>
                        @foreach (var dept in (List<Foras_Khadra.Models.Department>)ViewBag.Departments)
                        {
                            <button type="button"
                                    data-filter-value="@dept"
                                    class="filter-menu-item @(selectedDepartment == dept.ToString() ? "active" : "")">
                                @dept
                            </button>
                        }
                        </div>
                    </div>
                </div>
            </form>

            <a asp-action="Create" class="btn btn-add btn-one-line" style="background:#f99d27; color:#fff;">
                <i class="fa-solid fa-plus ms-1"></i> إضافة عضو
            </a>

            <a asp-controller="Admin" asp-action="Dashboard" class="btn-back-dashboard btn-one-line">
                <i class="fa-solid fa-gauge"></i>
                العودة للوحة التحكم
            </a>
        </div>
    </div>

    <div class="table-container mb-4">
        <div class="table-responsive" style="overflow-x:visible;">
            <table class="table articles-table">
                <thead>
                    <tr class="text-muted">
                        <th style="width:80px;"></th>
                        <th class="text-center">الاسم</th>
                        <th class="text-center">نوع العضوية</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var group in Model.GroupBy(m => m.Department))
                    {
                        <tr>
                                <td colspan="4" class="fw-bold text-dark" style="background:#f0f0f0;">
                                <h3 class="mb-0">@group.Key</h3>
                            </td>
                        </tr>

                        @foreach (var member in group.OrderByDescending(m => m.Membership))
                        {
                            <tr>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(member.ImagePath) ? "https://via.placeholder.com/50" : member.ImagePath)"
                                         class="rounded"
                                         style="width:50px;height:50px;object-fit:cover;"
                                         alt="عضو" />
                                </td>
                                <td class="fw-bold text-dark text-center">@member.NameAr</td>
                                <td class="text-muted text-center">@member.Membership</td>
                                <td>
                                    <div class="d-flex justify-content-end">
                                        <a asp-action="Details" asp-route-id="@member.Id" class="action-icon icon-view" title="عرض">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@member.Id" class="action-icon icon-edit" title="تعديل">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <button type="button"
                                                class="action-icon icon-delete"
                                                onclick="confirmDelete(@member.Id, '@member.NameAr')"
                                                title="حذف">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                        <form id="deleteForm-@member.Id"
                                              asp-action="Delete"
                                              asp-route-id="@member.Id"
                                              method="post"
                                              class="d-none">
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="articles-pagination d-flex align-items-center justify-content-between mt-4" dir="rtl">
        <p class="pagination-label m-0">انتقل إلى الصفحة التالية</p>

        <nav aria-label="Page navigation">
            <ul class="pagination m-0" style="direction:ltr;">

                <!-- السابق -->
                <li class="page-item @(page == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(page - 1)"
                       asp-route-search="@search"
                       asp-route-department="@selectedDepartment"
                       aria-label="Prev">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == 1 || i == totalPages || (i >= page - 1 && i <= page + 1))
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@search"
                               asp-route-department="@selectedDepartment">@i</a>
                        </li>
                    }
                    else if (i == page - 2 || i == page + 2)
                    {
                        <li class="page-item disabled"><span class="page-link">..</span></li>
                    }
                }

                <!-- التالي -->
                <li class="page-item @(page == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(page + 1)"
                       asp-route-search="@search"
                       asp-route-department="@selectedDepartment"
                       aria-label="Next">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
                function confirmDelete(id, title) {
                    Swal.fire({
                        html: `
                            <div style="text-align:center;">
        <img src="/images/delete.svg" style=";margin-bottom:14px;" />
                                <h5 style="margin:0 0 10px 0;font-weight:700;color:#000000;font-weight:bold;">
        هل أنت متأكد من حذف العضو ؟                        </h5>
                            </div>
                        `,
                        input: 'text',
                        inputValue: title,
                        inputAttributes: { readonly: true },
                        showCancelButton: true,
                        confirmButtonText: 'حذف',
                        cancelButtonText: 'تراجع',
                        reverseButtons: true,
                        buttonsStyling: false,
                        customClass: {
                            popup: 'swal-rtl-popup',
                            input: 'swal-rtl-input',
                            confirmButton: 'swal-btn swal-btn-danger',
                            cancelButton: 'swal-btn swal-btn-cancel'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            document.getElementById('deleteForm-' + id).submit();

                        }
                    });
                }

                (function () {
                    const filterToggle = document.getElementById('teamFilterToggle');
                    const filterMenu = document.getElementById('teamFilterMenu');
                    const filterInput = document.getElementById('departmentFilterInput');

                    if (!filterToggle || !filterMenu || !filterInput) return;

                    filterToggle.addEventListener('click', function (e) {
                        e.stopPropagation();
                        filterMenu.classList.toggle('is-open');
                    });

                    document.addEventListener('click', function (e) {
                        if (!filterMenu.contains(e.target) && !filterToggle.contains(e.target)) {
                            filterMenu.classList.remove('is-open');
                        }
                    });

                    filterMenu.querySelectorAll('.filter-menu-item').forEach(function (item) {
                        item.addEventListener('click', function () {
                            filterInput.value = item.dataset.filterValue || '';
                            item.closest('form').submit();
                        });
                    });
                })();
    </script>

    <style>
        /* RTL */
        .swal-rtl-popup {
            direction: rtl;
            border-radius: 12px;
        }

        .swal-rtl-input {
            text-align: center !important;
            border: none !important;
            box-shadow: none !important;
            background: transparent !important;
            font-weight: 600;
            color: #25652C;
            font-size: 16px;
            margin-top: 8px;
            pointer-events: none;
        }

        /* ترتيب الأزرار */
        .swal2-actions {
            display: flex !important;
            gap: 12px; /* 👈 المسافة بين الزرين */
        }

        /* Buttons style */
        .swal-btn {
            min-width: 120px;
            padding: 10px 18px;
            border-radius: 10px;
            font-weight: 700;
            border: none;
        }

        /* زر الحذف (يمين) */
        .swal-btn-danger {
            background: #ff383c;
            color: #fff;
        }

        /* زر التراجع (يسار) */
        .swal-btn-cancel {
            background: #fff;
            color: #f99d27;
            border: 2px solid #f99d27;
        }

        .btn-back-dashboard {
            background: transparent;
            color: #f99d27;
            border: 2px solid #f99d27;
            border-radius: 10px;
            padding: 8px 18px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-back-dashboard i {
            color: inherit;
        }

        .btn-back-dashboard:hover {
            background: #f99d27;
            color: #fff;
            border-color: #f99d27;
        }

        .btn-one-line {
            white-space: nowrap;
        }

        .search-wrapper-team {
            justify-content: space-between;
            gap: 8px;
        }

        .filter-dropdown {
            position: relative;
            margin: 0;
        }

        .filter-summary {
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 0;
            background: transparent;
        }

        .filter-menu {
            position: absolute;
            top: calc(100% + 10px);
            left: 0;
            min-width: 180px;
            background: #fff;
            border: 1px solid #eee;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
            padding: 6px;
            display: none;
            z-index: 50;
        }

        .filter-menu.is-open {
            display: block;
        }

        .filter-menu-item {
            width: 100%;
            border: 0;
            background: transparent;
            text-align: right;
            padding: 8px 10px;
            border-radius: 8px;
            color: #333;
            font-size: 14px;
            transition: background 0.2s ease;
        }

        .filter-menu-item:hover {
            background: #f3f7f4;
        }

        .filter-menu-item.active {
            background: #f99d27;
            color: #fff;
        }

    </style>
}
