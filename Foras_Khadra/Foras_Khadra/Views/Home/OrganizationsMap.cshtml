@model List<Foras_Khadra.Models.Organization>
@using System.Globalization
@using System.Text.Encodings.Web
@using System.Text.Json
@using Foras_Khadra.Helpers
@using Foras_Khadra.Models
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var fieldDir = lang == "ar" ? "rtl" : "ltr";
    var selectedCountry = ViewBag.SelectedCountry as string;
    var selectedSector = ViewBag.SelectedSector as string;
    var countriesLookup = ViewBag.CountriesLookup as IReadOnlyList<Country> ?? Array.Empty<Country>();
    var countryFilterOptions = ViewBag.CountryFilterOptions as IReadOnlyList<OrgMapSelectOption> ?? Array.Empty<OrgMapSelectOption>();
    var sectorFilterOptions = ViewBag.SectorFilterOptions as IReadOnlyList<OrgMapSelectOption> ?? Array.Empty<OrgMapSelectOption>();
    ViewData["Title"] = Localizer["PageTitle"].Value;
    var jsonOpts = new JsonSerializerOptions { Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
<link rel="stylesheet" href="~/css/all-opportunities.css" />
<link rel="stylesheet" href="~/css/OrgMap.css" />

<div class="page-wrapper container org-map-page">
    <header class="custom-header org-map-header">
        <div class="header-right">
            <div class="header-logo">
                <img src="/images/about_us_leaf.svg" alt="" />
            </div>
            <h1 class="header-title">@Localizer["PageTitle"]</h1>
        </div>

        <div class="header-left">
            <button type="button" class="filter-btn" id="filterToggleBtnOrg" aria-expanded="false" aria-controls="filterWindowOrg">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="4" y1="21" x2="4" y2="14"></line>
                    <line x1="4" y1="10" x2="4" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12" y2="3"></line>
                    <line x1="20" y1="21" x2="20" y2="16"></line>
                    <line x1="20" y1="12" x2="20" y2="3"></line>
                    <line x1="1" y1="14" x2="7" y2="14"></line>
                    <line x1="9" y1="8" x2="15" y2="8"></line>
                    <line x1="17" y1="16" x2="23" y2="16"></line>
                </svg>
            </button>
        </div>

        <div class="filter-window org-map-filter-window shadow-sm" id="filterWindowOrg" role="dialog" aria-label="@Localizer["filter_heading"]">
            <div class="filter-window-header">
                <span class="sort-by-label">
                    @Localizer["filter_heading"]
                    <i class="bi bi-caret-up-fill filter-heading-caret" aria-hidden="true"></i>
                </span>
                <a href="@Url.Action("OrganizationsMap", "Home")" class="reset-link">@Localizer["reset"]</a>
            </div>

            <form method="get" asp-action="OrganizationsMap" asp-controller="Home" class="org-map-filter-form">
                <div class="mb-3">
                    <label class="form-label org-map-label" for="orgMapCountry">@Localizer["country"]</label>
                    <select name="country"
                            id="orgMapCountry"
                            class="form-control border-1 shadow-sm org-map-select"
                            dir="@fieldDir">
                        @if (string.IsNullOrEmpty(selectedCountry))
                        {
                            <option value="" selected>@Localizer["AllCountries"]</option>
                        }
                        else
                        {
                            <option value="">@Localizer["AllCountries"]</option>
                        }
                        @foreach (var opt in countryFilterOptions)
                        {
                            if (string.Equals(selectedCountry, opt.Value, StringComparison.Ordinal))
                            {
                                <option value="@opt.Value" selected>@opt.Label</option>
                            }
                            else
                            {
                                <option value="@opt.Value">@opt.Label</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label org-map-label" for="orgMapSector">@Localizer["sector_label"]</label>
                    <select name="sector"
                            id="orgMapSector"
                            class="form-control border-1 shadow-sm org-map-select"
                            dir="@fieldDir">
                        @if (string.IsNullOrEmpty(selectedSector))
                        {
                            <option value="" selected>@Localizer["AllSectors"]</option>
                        }
                        else
                        {
                            <option value="">@Localizer["AllSectors"]</option>
                        }
                        @foreach (var opt in sectorFilterOptions)
                        {
                            if (string.Equals(selectedSector, opt.Value, StringComparison.Ordinal))
                            {
                                <option value="@opt.Value" selected>@opt.Label</option>
                            }
                            else
                            {
                                <option value="@opt.Value">@opt.Label</option>
                            }
                        }
                    </select>
                </div>

                <div class="org-map-filter-actions">
                    <button type="submit" class="btn-search-sub">@Localizer["apply"]</button>
                    <button type="button" class="btn-cancel-sub org-map-filter-close-btn" id="filterCloseBtnOrg">@Localizer["close"]</button>
                </div>
            </form>
        </div>
    </header>

    <div class="network-page">
        <div class="network-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var org in Model)
                {
                    var logoSrc = !string.IsNullOrEmpty(org.LogoPath) ? org.LogoPath : "/images/default-logo.png";
                    var sectorText = OrgMapFilterFormatting.SectorLabel(org.Sector, lang);
                    var countryText = OrgMapFilterFormatting.CountryLabel(org.Country, lang, countriesLookup);
                    <div class="org-wrapper">
                        <div class="org-card" data-org-id="@org.Id" dir="@fieldDir">
                            <div class="org-card-body">
                                <img class="org-logo"
                                     src="@logoSrc"
                                     alt=""
                                     loading="lazy" />
                                <div class="org-card-text">
                                    <div class="org-name" title="@org.Name">@org.Name</div>
                                    <div class="org-meta org-disc-sector" title="@sectorText">@sectorText</div>
                                    <div class="org-meta org-disc-country" title="@countryText">@countryText</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info text-center w-100 org-map-empty">
                    @Localizer["NoResults"]
                </div>
            }
        </div>
    </div>

    <div class="pagination-container org-map-pagination">
        @{
            var totalPages = (int)(ViewBag.TotalPages ?? 0);
        }
        @for (var i = 1; i <= totalPages; i++)
        {
            <a class="org-map-page-link @(ViewBag.CurrentPage == i ? "active" : null)"
               href="@Url.Action("OrganizationsMap", "Home", new { page = i, country = selectedCountry, sector = selectedSector })">@i</a>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    (function () {
        const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();
        const i18n = {
            loginTitle: @Html.Raw(JsonSerializer.Serialize(Localizer["LoginRequiredTitle"].Value, jsonOpts)),
            loginText: @Html.Raw(JsonSerializer.Serialize(Localizer["LoginRequiredText"].Value, jsonOpts)),
            loginBtn: @Html.Raw(JsonSerializer.Serialize(Localizer["LoginButton"].Value, jsonOpts))
        };

        const filterBtn = document.getElementById('filterToggleBtnOrg');
        const filterWindow = document.getElementById('filterWindowOrg');
        const closeBtn = document.getElementById('filterCloseBtnOrg');

        function setFilterOpen(open) {
            if (!filterWindow || !filterBtn) return;
            filterWindow.style.display = open ? 'block' : 'none';
            filterBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        }

        if (filterBtn && filterWindow) {
            filterBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                const open = filterWindow.style.display !== 'block';
                setFilterOpen(open);
            });

            closeBtn?.addEventListener('click', function (e) {
                e.stopPropagation();
                setFilterOpen(false);
            });

            document.addEventListener('click', function (e) {
                if (!filterWindow.contains(e.target) && e.target !== filterBtn) {
                    setFilterOpen(false);
                }
            });
        }

        document.querySelectorAll('.org-card').forEach(function (card) {
            card.addEventListener('dblclick', function () {
                const orgId = this.dataset.orgId;
                if (!isAuthenticated) {
                    Swal.fire({
                        icon: 'warning',
                        title: i18n.loginTitle,
                        text: i18n.loginText,
                        confirmButtonText: i18n.loginBtn,
                        confirmButtonColor: '#F99D27'
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            window.location.href = '/Account/Login';
                        }
                    });
                } else {
                    window.location.href = '/Home/DetailsOrganization/' + orgId;
                }
            });
        });
    })();
</script>
