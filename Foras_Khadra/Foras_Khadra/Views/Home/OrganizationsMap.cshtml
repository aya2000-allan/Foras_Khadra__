
@model List<Foras_Khadra.Models.Organization>

@{
    ViewData["Title"] = "شبكة المنظمات";
}

<link rel="stylesheet" href="~/css/OrgMap.css" />

<h2 class="mb-4">شبكة المنظمات</h2>

<div class="network-page">

    <!-- فلتر -->
    <form method="get" class="network-filter">

        <select name="country" class="form-control w-auto">
            <option value="">كل الدول</option>
            @foreach (var c in ViewBag.Countries)
            {
                <option value="@c" selected="@(ViewBag.SelectedCountry == c ? "selected" : null)">
                    @c
                </option>
            }
        </select>

        <select name="sector" class="form-control w-auto">
            <option value="">كل القطاعات</option>
            @foreach (var s in ViewBag.Sectors)
            {
                <option value="@s" selected="@(ViewBag.SelectedSector == s ? "selected" : null)">
                    @s
                </option>
            }
        </select>

        <button type="submit" class="btn btn-warning text-white px-4">
            فلتر
        </button>

    </form>

    <!-- GRID -->
    <div class="network-grid">

        @if (Model != null && Model.Any())
        {
            @foreach (var org in Model)
            {
                <!-- WRAPPER مهم للتفاصيل -->
                <div class="org-wrapper">

                    <!-- NODE -->
                    <div class="org-card" data-org-id="@org.Id">

                        <img class="org-logo"
                             src="@(!string.IsNullOrEmpty(org.LogoPhotoPath) ? org.LogoPhotoPath : "/images/default-logo.png")" />


                    </div>

                    <!-- DETAILS BOX -->
                    <div class="org-details">
                     <div><b>اسم المنظمة:</b>@org.Name</div>
                     <div><b>القطاع:</b> @org.Sector</div>
                     <div><b>الدولة:</b> @org.Country</div>
                    </div>

                </div>
            }
        }
        else
        {
            <div class="alert alert-info text-center w-100">
                لا توجد نتائج مطابقة
            </div>
        }

    </div>

</div>

<!-- PAGINATION -->
<div class="pagination-container">

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a class="page-number @(ViewBag.CurrentPage == i ? "active" : "")"
           href="@Url.Action("OrganizationsMap", new {
                page = i,
                country = ViewBag.SelectedCountry,
                sector = ViewBag.SelectedSector
           })">
            @i
        </a>
    }

</div>

<!-- SWEET ALERT -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();

    // 🔥 تفاصيل تظهر تحت كل node
    document.querySelectorAll(".org-card").forEach(card => {

        card.addEventListener("click", function (e) {

            const wrapper = this.parentElement;

            // toggle details
            document.querySelectorAll(".org-wrapper")
                .forEach(w => w.classList.remove("active"));

            wrapper.classList.add("active");

            // stop navigation conflict (optional)
            e.stopPropagation();
        });

    });

    // 🔥 فتح تفاصيل المنظمة (صفحة)
    document.querySelectorAll(".org-card").forEach(card => {

        card.addEventListener("dblclick", function () {

            const orgId = this.dataset.orgId;

            if (!isAuthenticated) {

                Swal.fire({
                    icon: "warning",
                    title: "تسجيل الدخول مطلوب",
                    text: "يجب تسجيل الدخول لعرض تفاصيل المنظمة",
                    confirmButtonText: "تسجيل الدخول",
                    confirmButtonColor: "#F99D27"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/Account/Login";
                    }
                });

            } else {
                window.location.href = "/Home/DetailsOrganization/" + orgId;
            }

        });

    });
</script>