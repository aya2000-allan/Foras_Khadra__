@model List<Foras_Khadra.Models.Organization>

@{
    ViewData["Title"] = "خريطة المنظمات";
}

<h2 class="mb-4">شبكة المنظمات</h2>

<!-- فلتر -->
<form method="get" class="mb-4 d-flex gap-2">

    <!-- الدولة -->
    <select name="country" class="form-control w-25">
        <option value="">كل الدول</option>

        @foreach (var c in ViewBag.Countries)
        {
            <option value="@c" selected="@(ViewBag.SelectedCountry == c ? "selected" : null)">
                @c
            </option>
        }
    </select>

    <!-- القطاع -->
    <select name="sector" class="form-control w-25">
        <option value="">كل القطاعات</option>

        @foreach (var s in ViewBag.Sectors)
        {
            <option value="@s" selected="@(ViewBag.SelectedSector == s ? "selected" : null)">
                @s
            </option>
        }
    </select>

    <button type="submit" class="btn btn-primary">فلتر</button>

</form>

<!-- الكروت -->
<div class="row">

    @if (Model != null && Model.Any())
    {
        @foreach (var org in Model)
        {
            <div class="col-md-4 mb-3">

                <div class="card h-100 shadow-sm org-card"
                     data-org-id="@org.Id"
                     style="cursor:pointer;">

                    <div class="card-body d-flex justify-content-between align-items-center">

                        <div>
                            <h5 class="mb-1">@org.Name</h5>

                            <p class="mb-0">
                                القطاع: @(string.IsNullOrWhiteSpace(org.Sector) ? "غير محدد" : org.Sector) <br />
                                الدولة: @(string.IsNullOrWhiteSpace(org.Country) ? "غير محدد" : org.Country)
                            </p>
                        </div>

                        <div>
                            <img src="@(!string.IsNullOrEmpty(org.LogoPath) ? org.LogoPath : "/images/default-logo.png")"
                                 style="width:60px;height:60px;object-fit:cover;border-radius:50%;" />
                        </div>

                    </div>
                </div>

            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                لا توجد نتائج مطابقة للفلتر
            </div>
        </div>
    }

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();

    document.querySelectorAll(".org-card").forEach(card => {

        card.addEventListener("click", function () {

            const orgId = this.dataset.orgId;

            if (!isAuthenticated) {

                Swal.fire({
                    icon: "warning",
                    title: "تسجيل الدخول مطلوب",
                    text: "يجب تسجيل الدخول لعرض تفاصيل المنظمة",
                    confirmButtonText: "تسجيل الدخول",
                    confirmButtonColor: "#F99D27"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/Account/Login";
                    }
                });

            } else {
                window.location.href = "/Home/DetailsOrganization/" + orgId;
            }

        });

    });
</script>
