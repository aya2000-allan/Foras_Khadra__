@model List<Foras_Khadra.Models.Organization>

@{
    ViewData["Title"] = "خريطة المنظمات";
}
<link rel="stylesheet" href="~/css/OrgMap.css" />
<h2 class="mb-4">شبكة المنظمات</h2>



<!-- الكروت -->
<div class="network-page">


    <!-- فلتر -->
    <form method="get" class="network-filter">

        <select name="country" class="form-control w-auto">
            <option value="">كل الدول</option>
            @foreach (var c in ViewBag.Countries)
            {
                <option value="@c" selected="@(ViewBag.SelectedCountry == c ? "selected" : null)">
                    @c
                </option>
            }
        </select>

        <select name="sector" class="form-control w-auto">
            <option value="">كل القطاعات</option>
            @foreach (var s in ViewBag.Sectors)
            {
                <option value="@s" selected="@(ViewBag.SelectedSector == s ? "selected" : null)">
                    @s
                </option>
            }
        </select>

        <button type="submit" class="btn btn-warning text-white px-4">
            فلتر
        </button>

    </form>

    <!-- Grid -->
    <div class="network-grid">

        @if (Model != null && Model.Any())
        {
            @foreach (var org in Model)
            {
                <div class="org-card org-card"
                     data-org-id="@org.Id">

                    <div class="d-flex align-items-center gap-3">

                        <img class="org-logo"
                             src="@(!string.IsNullOrEmpty(org.LogoPath) ? org.LogoPath : "/images/default-logo.png")" />

                        <div>
                            <div class="org-name">@org.Name</div>

                            <div class="org-meta">
                                @org.Sector <br />
                                @org.Country
                            </div>
                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="alert alert-info text-center w-100">
                لا توجد نتائج مطابقة
            </div>
        }

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();

    document.querySelectorAll(".org-card").forEach(card => {

        card.addEventListener("click", function () {

            const orgId = this.dataset.orgId;

            if (!isAuthenticated) {

                Swal.fire({
                    icon: "warning",
                    title: "تسجيل الدخول مطلوب",
                    text: "يجب تسجيل الدخول لعرض تفاصيل المنظمة",
                    confirmButtonText: "تسجيل الدخول",
                    confirmButtonColor: "#F99D27"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/Account/Login";
                    }
                });

            } else {
                window.location.href = "/Home/DetailsOrganization/" + orgId;
            }

        });

    });
</script>
