@model Foras_Khadra.Models.Organization

@{
    ViewData["Title"] = "تفاصيل المنظمة";
}

@using System.Globalization

@{
    string GetCountryName(string code)
    {
        var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

        return code switch
        {
            "JO" => lang == "ar" ? "الأردن" : lang == "fr" ? "Jordanie" : "Jordan",
            "PS" => lang == "ar" ? "فلسطين" : lang == "fr" ? "Palestine" : "Palestine",
            "EG" => lang == "ar" ? "مصر" : lang == "fr" ? "Égypte" : "Egypt",
            "YE" => lang == "ar" ? "اليمن" : lang == "fr" ? "Yémen" : "Yemen",
            "IN" => lang == "ar" ? "الهند" : lang == "fr" ? "Inde" : "India",
            "DZ" => lang == "ar" ? "الجزائر" : lang == "fr" ? "Algérie" : "Algeria",
            "LB" => lang == "ar" ? "لبنان" : lang == "fr" ? "Liban" : "Lebanon",
            "TN" => lang == "ar" ? "تونس" : lang == "fr" ? "Tunisie" : "Tunisia",
            "OM" => lang == "ar" ? "عُمان" : lang == "fr" ? "Oman" : "Oman",
            "IQ" => lang == "ar" ? "العراق" : lang == "fr" ? "Irak" : "Iraq",
            "MA" => lang == "ar" ? "المغرب" : lang == "fr" ? "Maroc" : "Morocco",
            "SY" => lang == "ar" ? "سوريا" : lang == "fr" ? "Syrie" : "Syria",
            _ => code
        };
    }
}

<h2 class="mb-4">@Model.Name</h2>

<div class="card shadow-sm p-3">

    

    <!-- المعلومات -->
    <p><b>القطاع:</b> @Model.Sector</p>
    <p><b>الدولة:</b> @GetCountryName(Model.Country)</p>
    <p><b>اسم جهة الاتصال:</b> @Model.ContactName</p>
    <p><b>البريد الإلكتروني:</b> @Model.ContactEmail</p>
    <p><b>رقم الهاتف:</b> @Model.PhoneNumber</p>

    @if (!string.IsNullOrEmpty(Model.Website))
    {
        <p>
            <b>الموقع الإلكتروني:</b>
            <a href="@Model.Website" target="_blank">@Model.Website</a>
        </p>
    }

    <!-- أيقونة الموقع -->
    @if (!string.IsNullOrEmpty(Model.Location))
    {
        

        <!-- خريطة -->
        <iframe width="100%"
                height="300"
                frameborder="0"
                style="border:0"
                loading="lazy"
                allowfullscreen
                src="https://www.google.com/maps?q=@Model.Location&output=embed">
        </iframe>
    }

</div>

<a asp-action="OrganizationsMap" class="btn btn-secondary mt-3">
    رجوع
</a>