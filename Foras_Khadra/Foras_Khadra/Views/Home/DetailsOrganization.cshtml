@model Foras_Khadra.Models.Organization
@using Microsoft.AspNetCore.Mvc.Localization
@using System.Globalization
@using System.Text.RegularExpressions
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var dir = culture == "ar" ? "rtl" : "ltr";
    var logoSrc = string.IsNullOrWhiteSpace(Model.LogoPath)
        ? Url.Content("~/images/about_us_leaf.svg")
        : Model.LogoPath;

    string GetCountryName(string code)
    {
        var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        return code switch
        {
            "JO" => lang == "ar" ? "الأردن" : lang == "fr" ? "Jordanie" : "Jordan",
            "PS" => lang == "ar" ? "فلسطين" : lang == "fr" ? "Palestine" : "Palestine",
            "EG" => lang == "ar" ? "مصر" : lang == "fr" ? "Égypte" : "Egypt",
            "YE" => lang == "ar" ? "اليمن" : lang == "fr" ? "Yémen" : "Yemen",
            "IN" => lang == "ar" ? "الهند" : lang == "fr" ? "Inde" : "India",
            "DZ" => lang == "ar" ? "الجزائر" : lang == "fr" ? "Algérie" : "Algeria",
            "LB" => lang == "ar" ? "لبنان" : lang == "fr" ? "Liban" : "Lebanon",
            "TN" => lang == "ar" ? "تونس" : lang == "fr" ? "Tunisie" : "Tunisia",
            "OM" => lang == "ar" ? "عُمان" : lang == "fr" ? "Oman" : "Oman",
            "IQ" => lang == "ar" ? "العراق" : lang == "fr" ? "Irak" : "Iraq",
            "MA" => lang == "ar" ? "المغرب" : lang == "fr" ? "Maroc" : "Morocco",
            "SY" => lang == "ar" ? "سوريا" : lang == "fr" ? "Syrie" : "Syria",
            _ => code
        };
    }

    var countryCode = Model.Country?.Trim() ?? "";
    var countryDisplay = GetCountryName(countryCode);

    // q=placeName triggers Google's place card in embed; ll=lat,lng centers without that popup.
    string mapSrc;
    if (!string.IsNullOrWhiteSpace(Model.Location))
    {
        var loc = Model.Location.Trim();
        if (Regex.IsMatch(loc, @"^-?\d+(\.\d+)?\s*,\s*-?\d+(\.\d+)?$", RegexOptions.CultureInvariant))
        {
            var parts = loc.Split(',', StringSplitOptions.TrimEntries);
            mapSrc = $"https://www.google.com/maps?ll={parts[0]},{parts[1]}&z=12&output=embed";
        }
        else
        {
            mapSrc = "https://www.google.com/maps?q=" + Uri.EscapeDataString(loc) + "&output=embed";
        }
    }
    else
    {
        var cc = countryCode switch
        {
            "JO" => (ok: true, lat: 31.0, lng: 36.0, z: 7),
            "PS" => (ok: true, lat: 31.9522, lng: 35.2332, z: 9),
            "EG" => (ok: true, lat: 26.820553, lng: 30.802498, z: 6),
            "YE" => (ok: true, lat: 15.552727, lng: 48.516388, z: 6),
            "IN" => (ok: true, lat: 20.5937, lng: 78.9629, z: 5),
            "DZ" => (ok: true, lat: 28.0339, lng: 1.6596, z: 5),
            "LB" => (ok: true, lat: 33.8547, lng: 35.8623, z: 9),
            "TN" => (ok: true, lat:  33.8869, lng: 9.5375, z: 7),
            "OM" => (ok: true, lat: 21.473533, lng: 55.975413, z: 7),
            "IQ" => (ok: true, lat: 33.223191, lng: 43.679291, z: 6),
            "MA" => (ok: true, lat: 31.791702, lng: -7.09262, z: 6),
            "SY" => (ok: true, lat: 34.802075, lng: 38.996815, z: 7),
            _ => (ok: false, lat: 0d, lng: 0d, z: 6)
        };

        if (cc.ok)
        {
            mapSrc = "https://www.google.com/maps?ll="
                + cc.lat.ToString(CultureInfo.InvariantCulture) + ","
                + cc.lng.ToString(CultureInfo.InvariantCulture)
                + "&z=" + cc.z.ToString(CultureInfo.InvariantCulture) + "&output=embed";
        }
        else
        {
            mapSrc = "https://www.google.com/maps?q=" + Uri.EscapeDataString(countryDisplay) + "&output=embed";
        }
    }
}

<link rel="stylesheet" href="~/css/org-details.css" />

<div class="org-details-page" dir="@dir">
    <div class="org-details-card">
        <header class="org-details-hero">
            <div class="org-details-hero-banner" dir="ltr">
                <p class="org-details-slogan" dir="@dir">@Localizer["HeroSlogan"]</p>
            </div>
        </header>

        <div class="org-details-content">
            <!-- dir=ltr يثبّت الخريطة يسار والمعلومات يمين بغض النظر عن لغة الصفحة -->
            <div class="org-details-split" dir="ltr">
                <aside class="org-details-map-col" dir="@dir">
                    <div class="org-details-map-card">
                        <div class="org-details-map-frame">
                            <iframe title="@countryDisplay"
                                    loading="lazy"
                                    allowfullscreen
                                    referrerpolicy="no-referrer-when-downgrade"
                                    src="@mapSrc"></iframe>
                        </div>
                        <div class="org-details-map-footer">
                            <iconify-icon icon="mdi:map-marker" aria-hidden="true"></iconify-icon>
                            <span>@countryDisplay</span>
                        </div>
                    </div>
                </aside>

                <div class="org-details-profile-col" dir="@dir">
                    <div class="org-details-profile-inner">
                        <div class="org-details-hero-logo">
                            <img src="@logoSrc" alt="" />
                        </div>
                        <div class="org-details-hero-heading">
                            <div class="org-details-title-row">
                                <h1 class="org-details-title">
                                    @Model.Name
                                    <span class="org-details-verified" title="@Localizer["Verified"]">
                                        <iconify-icon icon="mdi:check-decagram" aria-hidden="true"></iconify-icon>
                                    </span>
                                </h1>
                            </div>
                            <p class="org-details-subtitle">@Localizer["Subtitle"]</p>
                        </div>

                        <div class="org-details-rows">

                        <div class="org-detail-row">
                            <div class="org-detail-row-icon">
                                <iconify-icon icon="mdi:briefcase-outline" aria-hidden="true"></iconify-icon>
                            </div>
                            <div class="org-detail-row-text">
                                <span class="org-detail-row-label">@Localizer["LabelSector"]</span>
                                <span class="org-detail-row-value">@Model.Sector</span>
                            </div>
                        </div>

                        <div class="org-detail-row">
                            <div class="org-detail-row-icon">
                                <iconify-icon icon="mdi:earth" aria-hidden="true"></iconify-icon>
                            </div>
                            <div class="org-detail-row-text">
                                <span class="org-detail-row-label">@Localizer["LabelCountry"]</span>
                                <span class="org-detail-row-value">@countryDisplay</span>
                            </div>
                        </div>

                        <div class="org-detail-row">
                            <div class="org-detail-row-icon">
                                <iconify-icon icon="mdi:card-account-details-outline" aria-hidden="true"></iconify-icon>
                            </div>
                            <div class="org-detail-row-text">
                                <span class="org-detail-row-label">@Localizer["LabelContact"]</span>
                                <span class="org-detail-row-value">@Model.ContactName</span>
                            </div>
                        </div>

                        <div class="org-detail-row">
                            <div class="org-detail-row-icon">
                                <iconify-icon icon="mdi:email-outline" aria-hidden="true"></iconify-icon>
                            </div>
                            <div class="org-detail-row-text">
                                <span class="org-detail-row-label">@Localizer["LabelEmail"]</span>
                                <a class="org-detail-row-value" href="mailto:@Model.ContactEmail">@Model.ContactEmail</a>
                            </div>
                        </div>

                        <div class="org-detail-row">
                            <div class="org-detail-row-icon">
                                <iconify-icon icon="mdi:phone-outline" aria-hidden="true"></iconify-icon>
                            </div>
                            <div class="org-detail-row-text">
                                <span class="org-detail-row-label">@Localizer["LabelPhone"]</span>
                                <a class="org-detail-row-value" href="tel:@(Model.PhoneNumber?.Replace(" ", "").Replace("-", "") ?? "")">@Model.PhoneNumber</a>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Website))
                        {
                            var web = Model.Website!.Trim();
                            var webHref = web.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? web : "https://" + web;
                            <div class="org-detail-row">
                                <div class="org-detail-row-icon">
                                    <iconify-icon icon="mdi:web" aria-hidden="true"></iconify-icon>
                                </div>
                                <div class="org-detail-row-text">
                                    <span class="org-detail-row-label">@Localizer["LabelWebsite"]</span>
                                    <a class="org-detail-row-value" href="@webHref" target="_blank" rel="noopener noreferrer">@web</a>
                                </div>
                            </div>
                        }

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="OrganizationsMap" class="org-details-back">
        <iconify-icon icon="mdi:arrow-left" aria-hidden="true"></iconify-icon>
        @Localizer["BackToMap"]
    </a>
</div>
